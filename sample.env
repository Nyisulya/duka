# Django Production Settings Template
# Copy this file to '.env' and fill in your production values

# 1. Django Security Key (Generate a strong random key)
SECRET_KEY=django-insecure-WekaNenosiriLakoLaKipekeeNaImaraHapa

# 2. Debug Mode (Must be False in production)
DEBUG=False

# 3. Allowed Hosts (Comma separated domains or IPs that point to this server)
# Mfano: ALLOWED_HOSTS=domainyako.com,*.domainyako.com,123.45.67.89
ALLOWED_HOSTS=localhost,127.0.0.1

# 4. Database Connection URL (PostgreSQL Configuration)
# Mfano wa muundo: postgres://mtumiaji:nenosiri@host:port/database_name
# Kama ukiacha wazi, mfumo utatumia SQLite (db.sqlite3) kama kawaida kwa ajili ya majaribio
DATABASE_URL=postgres://duka_user:WekaNenosiriImaraHapa@localhost:5432/duka_db

# 5. Primary Domain ya Mfumo (Inatumika kusanidi Subdomains kwenye VPS)
# Mfano: PRIMARY_DOMAIN=duka.nyisu.com
# Kama ukiacha wazi, mfumo utatumia 'localhost' kwa default
PRIMARY_DOMAIN=duka.nyisu.com
